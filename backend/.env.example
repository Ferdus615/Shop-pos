# Application
NODE_ENV=development
PORT=3000
# Business timezone for sales/expense report boundaries (server may run in UTC)
APP_TIMEZONE=Asia/Dhaka

# Database (matches docker-compose.yml)
DB_HOST=localhost
# 5433 to avoid clashing with any Postgres already on 5432
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=shop_pos

# JWT auth
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# First owner account (created by `npm run seed`)
OWNER_NAME=Shop Owner
OWNER_EMAIL=owner@shop.local
OWNER_PASSWORD=owner123
